<div class="container py-4 text-center">
  <div class="row justify-content-center">
    <div class="col-12 col-xl-11">

      <div class="d-flex align-items-center justify-content-between mb-4">
        <button class="btn btn-custom-outline btn-sm px-3" (click)="volver()">
          <i class="bi bi-arrow-left me-1"></i> Volver
        </button>
        <h2 class="fun-title mb-0">Bici Rush: Mountain Downhill</h2>
        <div class="d-flex gap-3 align-items-center">
          <div class="pts-badge timer-badge tech-font">
            <i class="bi bi-stopwatch me-1"></i>{{ cronometro.tiempoFormateado() }}
          </div>
          <div class="pts-badge distance-badge tech-font">
            <i class="bi bi-bicycle me-1 text-warning"></i>{{ metros() }} / 2000m
          </div>
        </div>
      </div>

      <div class="card custom-card p-2 position-relative overflow-hidden bg-mountain-dark d-flex justify-content-center align-items-center">

        @if (!juegoCorriendo()) {
          <div class="py-5 animate-fade-in text-white">
            <p class="display-4 mb-3">🏔️🚴‍♂️🌲</p>
            <h3 class="fw-bold mb-2 text-accent-color">MTB EXTREMO: SENDERO NATURAL</h3>
            <p class="text-muted small max-w-text mx-auto mb-4">
              Presiona la barra de <strong>Espacio</strong> o haz clic sobre el lienzo para saltar troncos y rocas en el descenso. ¡Cruza la meta a los 2000 metros sanos y salvos!
            </p>
            <button class="btn btn-accent px-5 py-2.5 fw-bold rounded-pill shadow-lg" (click)="iniciarJuego()">
              <i class="bi bi-lightning-charge-fill me-1"></i> EMPEZAR DESCENSO
            </button>
          </div>
        }

        <canvas #gameCanvas width="1000" height="450"
                class="game-render-area"
                [class.d-none]="!juegoCorriendo() || juegoTerminado()"
                (click)="saltar()">
        </canvas>

        @if (juegoTerminado()) {
          <div class="py-5 animate-scale-up text-white">
            @if (victoria()) {
              <p class="display-3 mb-2">🏁🏆</p>
              <h3 class="text-success fw-bold text-uppercase tracking-widest">¡Meta Conquistada!</h3>
              <p class="text-light small">Completaste el circuito forestal sin caídas.</p>
            } @else {
              <p class="display-3 mb-2">💥🤕</p>
              <h3 class="text-danger fw-bold text-uppercase tracking-widest">Accidente en el Sendero</h3>
              <p class="text-light small">Has golpeado un obstáculo forestal.</p>
            }

            <p class="fun-title fs-4 mt-3 mb-4">Distancia Recorrida: {{ metros() }} metros</p>

            @if (guardando()) {
              <p class="text-muted small mb-3">
                <span class="spinner-border spinner-border-sm me-2"></span>Sincronizando registros con DB...
              </p>
            }

            <button class="btn btn-accent px-5 py-2.5 fw-bold rounded-pill" (click)="iniciarJuego()">
              <i class="bi bi-arrow-repeat me-2"></i>Volver a Intentar
            </button>
          </div>
        }

      </div>

    </div>
  </div>
</div>
