/* Fuentes */
@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;900&family=Righteous&display=swap');

@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;900&family=Rajdhani:wght@600;700&display=swap');

:root {
  --bg-base: #0e1117;
  --bg-card: #161b27;
  --bg-nav: rgba(14,17,23,0.92);
  --text-main: #e2e8f0;
  --text-muted: #b6c2d4;
  --black: #000000;
  --accent-primary: #6ee7f7;
  --accent-secondary: #a78bfa;
  --accent-logo: #6ee7f7;
  --accent-logo-rgb: 110,231,247;
  --accent-primary-rgb: 110,231,247;
  --white-rgb: 255,255,255;
  --black-rgb: 0,0,0;
}

body {
  background-color: var(--bg-base);
  color: var(--text-main);
  font-family: 'Nunito', sans-serif;
  margin: 0;
  min-height: 100vh;
  /* Patrón alimentado por variable blanca con 2% de opacidad */
  background-image: radial-gradient(rgba(var(--white-rgb), 0.02) 2px, transparent 2px);
  background-size: 30px 30px;
}

/* === TIPOGRAFÍA === */
.fun-title {
font-family: 'Righteous', cursive; /* La misma fuente del H1 del Home */
  font-size: 1.5rem;
  letter-spacing: 2px;
  color: var(--accent-logo) !important;
  text-transform: uppercase;
    /* 🌟 EFECTO DEGRADADO ARCADE (Sincronizado con el tope de las cards) */
  background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* === SOBREESCRITURAS CLAVES DE BOOTSTRAP === */
.text-primary { color: var(--accent-primary) !important; } 
.text-secondary { color: var(--text-muted) !important; }   

.bg-primary { background-color: var(--accent-primary) !important; color: var(--black) !important; }

.badge.bg-secondary { 
  background-color: rgba(var(--white-rgb), 0.05) !important; 
  border: 1px solid rgba(var(--white-rgb), 0.1); 
  color: var(--text-muted) !important; 
}

hr.text-muted { border-color: rgba(var(--white-rgb), 0.1); opacity: 1; }

/* === TARJETAS === */
.custom-card {
  background-color: var(--bg-card) !important;
  border-radius: 16px; 
  border: 1px solid rgba(var(--white-rgb), 0.03) !important; 
  box-shadow: 0 8px 24px rgba(var(--black-rgb), 0.4) !important; 
  transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease; 
}

/* El toque interactivo */
.custom-card:hover {
  transform: translateY(-4px); 
  border-color: var(--accent-primary) !important;
  /* La sombra oscura + el brillo de color alimentado por el RGB del acento */
  box-shadow: 0 10px 25px rgba(var(--black-rgb), 0.5), 0 0 15px rgba(var(--accent-primary-rgb), 0.10) !important;
}

/* === NAVBAR === */
.custom-navbar {
  background-color: var(--bg-nav) !important; 
  border-bottom: 0.5px solid var(--text-muted) !important; 
  /* Resplandor alimentado por el RGB del acento principal */
  box-shadow: 0 4px 6px rgba(var(--accent-primary-rgb), 0.15) !important;
  backdrop-filter: blur(10px); 
}

.custom-navbar .nav-link {
  color: var(--text-muted) !important;
  font-weight: 700;
  font-size: 1.1rem;
  transition: all 0.3s ease;
}

.custom-navbar .nav-link:hover, 
.custom-navbar .nav-link.active {
  color: var(--accent-primary) !important;
  /* Brillo del texto alimentado por el RGB del acento */
  text-shadow: 0 0 8px rgba(var(--accent-primary-rgb), 0.4); 
}

/* ======================================================= */
/* ALERTA DE ERROR ANIMADA                                 */
/* ======================================================= */
.custom-alert {
  background-color: rgba(220, 53, 69, 0.1) !important;
  border: 1px solid rgba(220, 53, 69, 0.4) !important;
  color: #ff6b6b !important;
  
  /* Llama a la animación que creamos abajo */
  animation: slideDownFade 0.3s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
}

/* La magia del deslizamiento suave */
@keyframes slideDownFade {
  0% {
    opacity: 0;
    transform: translateY(-40px); /* Arranca un poco más arriba y transparente */
  }
  100% {
    opacity: 1;
    transform: translateY(0); /* Llega a su posición final */
  }
}

/* --- Botón Principal (Accent Primary) --- */
.btn-accent {
  background-color: var(--accent-primary);
  /* Texto oscuro (--bg-base) para que contraste perfecto con el cyan claro */
  color: var(--bg-base); 
  border: none;
  transition: all 0.3s ease;
}

.btn-accent:hover:not(:disabled) {
  background-color: var(--accent-primary);
  color: var(--bg-base);
  /* Oscurece apenitas el botón y le da un brillo cyan */
  filter: brightness(0.9);
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(var(--accent-primary-rgb), 0.4);
}
