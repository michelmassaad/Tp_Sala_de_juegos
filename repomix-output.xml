/* ═══════════════════════════════════════════════════════════════════════
   AHORCADO — CSS COMPLETO COMPACTO Y UNIFICADO (SÚPER RESPONSIVE)
   Estructura fluida basada en unidades REM y CLAMP para alta fidelidad.
   ═══════════════════════════════════════════════════════════════════════ */

/* ─────────────────────────────────────────
   UTILITARIOS GLOBALES
───────────────────────────────────────── */
.tech-font {
  font-family: 'Rajdhani', 'Righteous', sans-serif;
  font-weight: 700;
}

/* ═══════════════════════════════════════════════════════════════════════
   1. WRAPPER BASE — Respeta estrictamente tu configuración de altura fija
═══════════════════════════════════════════════════════════════════════ */
.ahorcado-wrapper {
  height: calc(80vh);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
  background: transparent;
  color: var(--text-main);
}

.canvas-texture {
  position: absolute;
  inset: 0;
  background-image: radial-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px);
  background-size: 24px 24px;
  pointer-events: none;
  z-index: 0;
}

/* ═══════════════════════════════════════════════════════════════════════
   2. PANTALLA DE SELECCIÓN DE CATEGORÍAS
═══════════════════════════════════════════════════════════════════════ */
.menu-screen {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2.5rem 1.5rem; /* Manteniendo tus medidas en rem unificadas */
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start; /* 🚀 CAMBIO: flex-start para que en celulares comience bien desde el título arriba */
  
  /* 🌟 LA MAGIA PARA ACTIVAR EL SCROLLMÓVIL */
  flex: 1;                     /* Obliga a la pantalla del menú a ocupar el alto disponible */
  overflow-y: auto;            /* Habilita el scroll vertical únicamente dentro de esta pantalla */
  overflow-x: hidden;          /* Evita cualquier juego horizontal extraño */
  
  /* Scrollbar estético sutil estilo Arcade */
  scrollbar-width: thin;
  scrollbar-color: rgba(var(--accent-primary-rgb), 0.3) transparent;
}

.menu-screen .title-neon {
  font-family: 'Righteous', 'Kanit', cursive;
  font-size: clamp(2.5rem, 6vw, 4.2rem); 
  font-weight: 900;
  color: var(--accent-logo) !important; 
  letter-spacing: 2px;
  line-height: 1.1;
  text-shadow: 0 0 20px rgba(var(--accent-primary-rgb), 0.3);
}

.menu-screen .text-purple-muted {
  font-size: clamp(0.75rem, 1.5vw, 1.1rem) !important;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-weight: 700;
  line-height: 1.4 !important; 
  max-width: 100%; 
  background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  display: inline-block; 
}

.categories-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center; 
  gap: 1.15rem;
  width: 100%;
  margin-top: 2rem;
}

/* ── Tarjetas de Categorías ── */
.category-card {
  background: var(--bg-card);
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.05);
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  flex: 1 1 250px; 
  max-width: 275px; 
}

.category-card:hover {
  transform: translateY(-6px);
  border-color: rgba(var(--accent-primary-rgb), 0.35);
  box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5), 0 0 20px rgba(var(--accent-primary-rgb), 0.1);
}

.category-card .card-top-bar {
  height: 3px;
  background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));
  opacity: 0.3;
  transition: opacity 0.3s ease;
}
.category-card:hover .card-top-bar { opacity: 1; }

.category-card .card-img-area {
  width: 100%;
  height: 140px;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.card-img-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
  background-size: 20px 20px;
  pointer-events: none;
  z-index: 1;
}

.category-emoji-huge {
  font-size: 3.5rem;
  z-index: 2;
  transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  filter: drop-shadow(0 4px 8px rgba(0,0,0,0.5));
}
.category-card:hover .category-emoji-huge { transform: scale(1.15) rotate(5deg); }

.card-body-mini {
  padding: 1.1rem;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  flex: 1;
}

.category-card .card-title {
  font-size: 1.05rem;
  font-weight: 700;
  letter-spacing: 1px;
  color: var(--text-main);
  margin: 0;
  text-transform: uppercase;
}

.category-card .card-desc {
  font-size: 0.82rem;
  color: var(--text-muted);
  margin: 0;
  line-height: 1.4;
  margin-bottom: 0.75rem;
}

.category-card .card-badge {
  position: absolute;
  top: 12px;
  right: 12px;
  background: rgba(var(--accent-primary-rgb), 0.08);
  border: 1px solid rgba(var(--accent-primary-rgb), 0.25);
  color: var(--accent-primary);
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 1px;
  padding: 2px 8px;
  border-radius: 4px;
  z-index: 2;
}

.cat-action-play {
  display: flex;
  align-items: center;
  margin-top: auto; 
  padding: 0.5rem 0.75rem;
  border-radius: 8px;
  background: rgba(var(--accent-primary-rgb), 0.04);
  border: 1px solid rgba(var(--accent-primary-rgb), 0.15);
  color: var(--accent-primary);
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 1px;
  transition: all 0.25s ease;
}
.category-card:hover .cat-action-play { background: rgba(var(--accent-primary-rgb), 0.12); border-color: rgba(var(--accent-primary-rgb), 0.4); color: var(--text-main); }

.action-btn-back {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 0.75rem 2rem;
  border-radius: 14px;
  background: var(--bg-card);
  border: 1px solid rgba(255, 255, 255, 0.05);
  color: var(--text-muted);
  font-size: 0.88rem;
  font-weight: 700;
  letter-spacing: 1px;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(0,0,0,0.2);
  margin-top: 2rem;
}
.action-btn-back i { color: var(--accent-primary); }
.action-btn-back:hover { transform: translateY(-3px); border-color: rgba(var(--accent-primary-rgb), 0.4); color: var(--accent-primary); }

/* Modificadores exclusivos de categorías en pantallas grandes */
@media (min-width: 1400px) {
  .menu-screen { max-width: 1450px; }
  .categories-grid { gap: 1.5rem; }
  .category-card { max-width: 320px; flex-basis: 280px; border-radius: 20px; }
  .category-card .card-img-area { height: 180px; }
  .category-emoji-huge { font-size: 4.2rem; }
  .card-body-mini { padding: 1.5rem; gap: 0.6rem; }
  .category-card .card-title { font-size: 1.15rem; }
  .category-card .card-desc { font-size: 0.88rem; }
}

@media (max-width: 576px) {
  .categories-grid { flex-direction: column; align-items: center; }
  .category-card { max-width: 100%; width: 100%; }
  .action-btn-back { width: 100%; justify-content: center; }
}

/* ═══════════════════════════════════════════════════════════════════════
   3. GAME LAYOUT
═══════════════════════════════════════════════════════════════════════ */
.game-layout {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  overflow: hidden;
  position: relative;
  z-index: 1;
}

/* ═══════════════════════════════════════════════════════════════════════
   4. HUD (BARRA SUPERIOR)
═══════════════════════════════════════════════════════════════════════ */
.game-hud {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 clamp(0.75rem, 2vw, 1.5rem);
  height: clamp(52px, 7svh, 66px);
  flex-shrink: 0;
  background: rgba(14, 17, 23, 0.97);
  border-bottom: 1px solid rgba(var(--accent-primary-rgb), 0.12);
  gap: 8px;
}

.hud-left { display: flex; flex-direction: column; line-height: 1.1; min-width: 0; flex-shrink: 1; }
.hud-cat { font-size: clamp(0.6rem, 1.2vw, 0.8rem); letter-spacing: 2px; color: var(--text-muted); text-transform: uppercase; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.hud-nivel { font-size: clamp(1rem, 2vw, 1.4rem); color: var(--accent-logo); white-space: nowrap; }

.hud-lives { display: flex; align-items: center; gap: clamp(4px, 0.8vw, 10px); font-size: clamp(1rem, 1.8vw, 1.45rem); flex-shrink: 0; }
.life-active { color: #f87171; filter: drop-shadow(0 0 5px rgba(248, 113, 113, 0.7)); }
.life-lost { color: rgba(255, 255, 255, 0.12); }

.hud-right { display: flex; align-items: center; gap: clamp(6px, 0.8vw, 12px); flex-shrink: 0; }
.pts-badge { display: inline-flex; align-items: center; gap: 5px; padding: 0.35rem clamp(0.5rem, 1vw, 1rem); border-radius: 50px; font-size: clamp(0.72rem, 1vw, 0.92rem); white-space: nowrap; }
.timer-badge { background: rgba(6, 182, 212, 0.1); border: 1px solid rgba(6, 182, 212, 0.3); color: #06b6d4; }
.coins-badge { background: rgba(234, 179, 8, 0.1); border: 1px solid rgba(234, 179, 8, 0.3); color: #eab308; }
.coins-label { display: none; }

.btn-menu-hud {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: transparent;
  border: 1px solid rgba(var(--accent-primary-rgb), 0.35);
  color: var(--accent-primary);
  padding: 0.35rem clamp(0.5rem, 1vw, 1rem);
  border-radius: 50px;
  font-size: clamp(0.72rem, 1vw, 0.92rem);
  cursor: pointer;
  transition: background 0.2s ease;
}
.btn-menu-hud:hover { background: rgba(var(--accent-primary-rgb), 0.1); }

/* ═══════════════════════════════════════════════════════════════════════
   5. GAME ARENA (DISTRIBUCIÓN DE COMBATE)
═══════════════════════════════════════════════════════════════════════ */
.game-arena {
  flex: 1;
  display: flex;
  flex-direction: row;
  gap: clamp(10px, 1.5vw, 16px);
  padding: clamp(10px, 1.5svh, 16px) clamp(12px, 2vw, 20px);
  min-height: 0;
  overflow: hidden;
}

/* ── PANEL IZQUIERDO: Monigote e Incorrectas ── */
.arena-left {
  flex: 0 0 45%; 
  display: flex;
  flex-direction: column;
  gap: 12px;
  min-height: 0;
}

.hangman-frame {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(var(--accent-primary-rgb), 0.2);
  border-radius: 14px;
  overflow: hidden;
  min-height: 0;
}

.hangman-img {
  max-width: 90%;
  max-height: 90%;
  object-fit: contain;
  image-rendering: pixelated;
  filter: drop-shadow(0 0 14px rgba(var(--accent-primary-rgb), 0.2));
}

.wrong-zone {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(var(--accent-primary-rgb), 0.2);
  border-radius: 14px;
  padding: 0.5rem 0.75rem;
  min-height: 50px;
}
.wrong-chips { display: flex; flex-wrap: wrap; justify-content: center; gap: 6px; }

.chip-fail {
  width: 1.85rem;  /* Proporciones fluidas en rem */
  height: 1.85rem;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(220, 53, 69, 0.12);
  border: 1px solid rgba(220, 53, 69, 0.35);
  color: #f87171;
  font-size: 0.88rem;
  animation: chipIn 0.18s ease;
}
.chip-none { font-size: 0.82rem; color: rgba(255, 255, 255, 0.25); font-style: italic; letter-spacing: 1px; }

/* ── PANEL DERECHO: Centro operativo de la palabra ── */
.arena-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12px;
  min-height: 0;
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(var(--accent-primary-rgb), 0.2);
  border-radius: 14px;
  padding: 1.25rem;
}

.word-display-box {
  margin-top: auto;
  margin-bottom: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.35);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 14px;
  padding: 2.2rem 0.75rem; /* Removido padding fijo de 40px */
  min-height: 0;
  overflow: hidden;
}

.word-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 0.65rem;
  width: 80%;
}

/* 🚀 EL ENCUADRE ELÁSTICO AUTOMÁTICO */
.word-tile {
  flex: 0 1 3.2rem; 
  width: 100%;
  aspect-ratio: 3 / 4; 
  max-height: 55px;
  min-width: 18px;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Righteous', cursive;
  font-weight: 900;
  background: rgba(255, 255, 255, 0.02);
  border: 2px solid rgba(var(--accent-primary-rgb), 0.2);
  color: transparent;
  box-shadow: inset 0 0 10px rgba(0,0,0,0.5);
  transition: all 0.2s ease;
  font-size: clamp(0.9rem, 2.5vh, 1.5rem);
}

.word-tile.tile-on {
  background: rgba(var(--accent-primary-rgb), 0.05);
  border-color: var(--accent-primary);
  color: var(--accent-primary);
  text-shadow: 0 0 10px rgba(var(--accent-primary-rgb), 0.6);
  box-shadow: 0 0 15px rgba(var(--accent-primary-rgb), 0.15);
}

.hint-panel {
  flex-shrink: 0;
  background: rgba(0, 0, 0, 0.25);
  border: 1px solid rgba(var(--accent-primary-rgb), 0.15);
  border-left: 4px solid var(--accent-primary);
  border-radius: 10px;
  padding: 0.65rem 0.85rem;
}

.hint-label {
  display: block;
  font-size: 0.82rem;
  letter-spacing: 1.5px;
  color: var(--accent-primary);
  text-transform: uppercase;
  margin-bottom: 4px;
}
.hint-text { font-size: 0.95rem; color: #e2e8f0; margin: 0; line-height: 1.3; }

.utilities-row { flex-shrink: 0; display: flex; gap: 10px; }

.util-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.65rem 0.85rem;
  border-radius: 8px;
  font-size: 0.9rem;
  cursor: pointer;
  background: rgba(0, 0, 0, 0.2);
  transition: all 0.2s ease;
  min-width: 0;
}
.util-text { display: flex; align-items: center; gap: 5px; text-overflow: ellipsis; white-space: nowrap; }
.util-cost { display: flex; align-items: center; gap: 3px; background: rgba(255, 255, 255, 0.07); padding: 2px 6px; border-radius: 4px; font-size: 0.78rem; }
.util-cost .bi-coin { color: #eab308; }

.util-cyan { border: 1px solid rgba(var(--accent-primary-rgb), 0.4); color: var(--accent-primary); }
.util-cyan:hover:not(:disabled) { background: rgba(var(--accent-primary-rgb), 0.08); transform: translateY(-1px); }
.util-purple { border: 1px solid rgba(167, 139, 250, 0.4); color: var(--accent-secondary); }
.util-purple:hover:not(:disabled) { background: rgba(167, 139, 250, 0.08); transform: translateY(-1px); }
.util-btn:disabled { opacity: 0.22; cursor: not-allowed; }

/* ═══════════════════════════════════════════════════════════════════════
   6. KEYBOARD ZONE
═══════════════════════════════════════════════════════════════════════ */
.keyboard-zone {
  flex-shrink: 0;
  padding: 10px;
  background: rgba(0, 0, 0, 0.18);
  border-top: 1px solid rgba(255, 255, 255, 0.04);
}

.teclado {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 6px;
  max-width: 1000px;
  margin: 0 auto;
  width: 80%;
}

/* 🎰 TECLAS 3D UNIFICADAS EN REM */
.key {
  flex: 0 1 2.35rem;
  height: 2.35rem;
  width: 100%;
  max-width: 42px;
  border-radius: 6px;
  background: var(--bg-card);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: var(--text-main);
  font-family: 'Righteous', cursive;
  font-weight: 700;
  font-size: 0.95rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.1s ease;
  box-shadow: 0 3px 0 rgba(0,0,0,0.4);
  text-transform: uppercase;
  user-select: none;
}
.key:hover:not(:disabled) { background: rgba(var(--accent-primary-rgb), 0.12); border-color: rgba(var(--accent-primary-rgb), 0.5); color: var(--accent-primary); transform: translateY(-2px); box-shadow: 0 5px 0 rgba(0,0,0,0.4); }
.key:active:not(:disabled) { transform: translateY(1px); box-shadow: 0 1px 0 rgba(0,0,0,0.4); }
.key-ok { background: rgba(74, 222, 128, 0.12) !important; border-color: rgba(74, 222, 128, 0.5) !important; color: #4ade80 !important; box-shadow: 0 3px 0 rgba(0,0,0,0.3) !important; }
.key-fail { background: rgba(220, 53, 69, 0.03) !important; border-color: rgba(220, 53, 69, 0.08) !important; color: rgba(220, 53, 69, 0.2) !important; box-shadow: none !important; opacity: 0.3 !important; }
.key:disabled { cursor: not-allowed; }

/* ═══════════════════════════════════════════════════════════════════════
   7. MODAL DE RESULTADOS AISLADO
═══════════════════════════════════════════════════════════════════════ */
.result-overlay {
  position: absolute;
  inset: 0;
  background: rgba(10, 12, 16, 0.5);
  /* backdrop-filter: blur(8px); */
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  padding: 20px;
  box-sizing: border-box;
  overflow-y: auto !important; 
}

.result-card {
  background: var(--bg-card) !important;
  border-radius: 20px;
  border: 1px solid rgba(255, 255, 255, 0.08) !important;
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
  width: 100% !important;
  max-width: 370px !important; 
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.7);
  flex-shrink: 0; 
  margin: auto;
}

.result-top-bar { height: 3px; width: 100%; flex-shrink: 0; }
.overlay-win  .result-top-bar { background: #4ade80 !important; box-shadow: 0 0 12px #4ade80; }
.overlay-lose .result-top-bar { background: #f87171 !important; box-shadow: 0 0 12px #f87171; }

.result-img-area {
  width: 100%;
  height: clamp(110px, 17vh, 150px) !important; 
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}

.result-grid-texture {
  position: absolute;
  inset: 0;
  background-image: linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
  background-size: 20px 20px;
  pointer-events: none;
}

.result-char-img { max-height: 90% !important; max-width: 90% !important; object-fit: contain !important; image-rendering: pixelated; z-index: 2; }
.result-status { position: absolute; top: 10px; right: 10px; font-size: 0.55rem; font-weight: 700; letter-spacing: 1px; padding: 2px 6px; border-radius: 4px; z-index: 2; }
.overlay-win  .result-status { background: rgba(74, 222, 128, 0.12) !important; border: 1px solid rgba(74, 222, 128, 0.4) !important; color: #4ade80 !important; }
.overlay-lose .result-status { background: rgba(248, 113, 113, 0.12) !important; border: 1px solid rgba(248, 113, 113, 0.4) !important; color: #f87171 !important; }

.result-body { padding: 0.9rem 1.25rem 1.25rem; display: flex; flex-direction: column; gap: 4px; }
.result-title { font-size: clamp(1.2rem, 3.5vh, 1.65rem) !important; font-family: 'Righteous', cursive; text-transform: uppercase; text-align: center; margin: 0; }
.text-win-neon  { color: #4ade80 !important; text-shadow: 0 0 8px rgba(74, 222, 128, 0.4) !important; }
.text-lose-neon { color: #f87171 !important; text-shadow: 0 0 8px rgba(248, 113, 113, 0.4) !important; }

.arcade-result-card .mt-3 { margin-top: 10px !important; }
.arcade-result-card .mt-4 { margin-top: 14px !important; }

.decoded-box { background: rgba(0, 0, 0, 0.45); border-radius: 10px; padding: 10px; display: flex; flex-direction: column; gap: 2px; flex-shrink: 0; }
.border-win  { border: 1px solid rgba(74, 222, 128, 0.2); border-left: 4px solid #4ade80; }
.border-lose { border: 1px solid rgba(248, 113, 113, 0.2); border-left: 4px solid #f87171; }
.decoded-label { font-size: 0.6rem; letter-spacing: 1.5px; color: var(--text-muted); text-align: center; text-transform: uppercase; }
.decoded-word { font-family: 'Righteous', cursive; font-size: clamp(1.1rem, 3vw, 1.45rem); letter-spacing: 2px; text-transform: uppercase; color: var(--text-main); text-align: center; }

.result-metrics { background: rgba(0, 0, 0, 0.4) !important; border: 1px solid rgba(255, 255, 255, 0.04) !important; border-radius: 12px; padding: 2px 14px; flex-shrink: 0; }
.metric-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0 !important; border-bottom: 1px dashed rgba(255, 255, 255, 0.06); font-size: 0.85rem !important; }
.metric-row.no-border { border-bottom: none; }
.metric-label { color: #94a3b8 !important; }
.metric-value { color: #f8fafc !important; }
.metric-info  { color: #22d3ee !important; }
.overlay-lose .metric-row span.text-muted { color: #64748b !important; }

.result-actions { display: flex; flex-direction: column; gap: 8px; }
.btn-result-primary {
  display: flex; align-items: center; justify-content: center; width: 100%; padding: 0.65rem; border-radius: 8px;
  background: rgba(110, 231, 247, 0.06) !important; border: 1px solid rgba(110, 231, 247, 0.4) !important;
  color: #6ee7f7 !important; font-size: 0.88rem !important; font-weight: 700; letter-spacing: 1px; cursor: pointer; transition: all 0.2s ease;
}
.btn-result-primary:hover { background: #6ee7f7 !important; color: #0e1117 !important; box-shadow: 0 0 15px rgba(110, 231, 247, 0.4) !important; }

.btn-result-secondary {
  display: flex; align-items: center; justify-content: center; width: 100%; padding: 0.6rem; border-radius: 8px;
  background: rgba(255, 255, 255, 0.03) !important; border: 1px solid rgba(255, 255, 255, 0.08) !important;
  color: #94a3b8 !important; font-size: 0.82rem !important; font-weight: 700; letter-spacing: 1px; cursor: pointer; transition: all 0.2s ease;
}
.btn-result-secondary:hover { background: rgba(255, 255, 255, 0.08) !important; color: #ffffff !important; border-color: rgba(255, 255, 255, 0.2) !important; }

/* ═══════════════════════════════════════════════════════════════════════
   8. ANIMACIONES
═══════════════════════════════════════════════════════════════════════ */
.animate-fade-in  { animation: fadeIn 0.3s ease forwards; }
.animate-scale-up { animation: scaleUp 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; }
.shake-effect     { animation: shake 0.35s cubic-bezier(.36,.07,.19,.97) both; }

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes scaleUp { from { opacity: 0; transform: scale(0.88); } to { opacity: 1; transform: scale(1); } }
@keyframes chipIn { from { transform: scale(0.5); opacity: 0; } to { transform: scale(1); opacity: 1; } }
@keyframes shake { 10%, 90% { transform: translate3d(-1px, 0, 0); } 20%, 80% { transform: translate3d(2px, 0, 0); } 30%, 50%, 70% { transform: translate3d(-3px, 0, 0); } 40%, 60% { transform: translate3d(3px, 0, 0); } }

/* ═══════════════════════════════════════════════════════════════════════
   9. RESPONSIVE — DESKTOP (≥ 769px)
═══════════════════════════════════════════════════════════════════════ */
@media (min-width: 769px) {
  .coins-label { display: inline; }
  .result-overlay {
    justify-content: flex-end;
    align-items: center;
    padding-right: 6% !important;
    background: rgba(10, 12, 16, 0.45); /* Limpiado a formato estándar nítido */
  }
}

/* =======================================================================
   🚀 UNIFICACIÓN PREMIUM: ESCALADO GLOBAL PARA PANTALLAS GRANDES (≥ 1200px)
   Ajusta proporcionalmente todas las fuentes, botones y fichas interactivos.
   ======================================================================= */

@media (min-width: 1200px) {
  
  /* 1. HUD Superior Unificado */
  .game-hud {
    height: 74px !important; /* Más presencia vertical de la barra de estado */
    padding: 0 2rem !important;
  }
  .hud-nivel { font-size: 1.6rem !important; }
  .hud-cat { font-size: 0.88rem !important; }
  .hud-lives { font-size: 1.6rem !important; gap: 10px !important; }
  .pts-badge, .btn-menu-hud { font-size: 1.05rem !important; padding: 0.45rem 1.25rem !important; }

  /* 2. Distribución y Márgenes de Arena */
  .game-arena {
    gap: 20px !important;
    padding: 20px 24px !important;
  }

  /* Fichas de Letras Incorrectas */
  .wrong-zone { min-height: 60px !important; }
  .chip-fail {
    width: 2.2rem !important;  /* Escalado simétrico para que no queden enanas */
    height: 2.2rem !important;
    font-size: 1.1rem !important;
    border-radius: 8px !important;
  }
  .chip-none { font-size: 0.95rem !important; }

  /* 3. Panel Derecho: Casilleros de la Palabra */
  .word-display-box {
    padding: 2.8rem 1.5rem !important; 
    max-height: 150px !important;
  }
  .word-row { gap: 0.85rem !important; }
  
  .word-tile {
    flex: 0 1 4.2rem !important;    /* Ancho ideal para respirar en escritorio */
    max-height: 76px !important;    /* Mantiene la proporción 3/4 rigurosamente */
    font-size: 2rem !important;      /* Letra descubierta imponente */
    border-width: 3px !important;    /* Más grosor de borde estilo Arcade */
    border-radius: 10px !important;
  }

  /* Panel de Pistas */
  .hint-panel { padding: 0.85rem 1.1rem !important; }
  .hint-label { font-size: 0.9rem !important; margin-bottom: 6px !important; }
  .hint-text { font-size: 1.1rem !important; }

  /* Botones de Utilidades / Poderes */
  .util-btn { padding: 0.8rem 1.2rem !important; font-size: 1.05rem !important; border-radius: 10px !important; }
  .util-cost { font-size: 0.9rem !important; padding: 3px 8px !important; }

  /* 4. Zona Inferior del Teclado */
  .keyboard-zone { padding: 16px !important; }
  .teclado { gap: 7px !important; }
  
  .key {
    flex: 0 1 2.8rem !important;   /* Teclas más robustas y fáciles de clickear */
    height: 2.8rem !important;
    max-width: 46px !important;
    font-size: 1.15rem !important;  /* Tipografía unificada de la letra */
    border-radius: 8px !important;
    box-shadow: 0 4px 0 rgba(0, 0, 0, 0.4) !important; /* Incrementamos relieve 3D */
  }
  .key:hover:not(:disabled) { transform: translateY(-3px) !important; box-shadow: 0 7px 0 rgba(0, 0, 0, 0.4) !important; }
  .key:active:not(:disabled) { transform: translateY(1px) !important; box-shadow: 0 1px 0 rgba(0, 0, 0, 0.4) !important; }
}

/* ═══════════════════════════════════════════════════════════════════════
   🖥️ MONITOR GIGANTE / PANTALLAS ULTRA-WIDE (≥ 1600px)
   ═══════════════════════════════════════════════════════════════════════ */
@media (min-width: 1600px) {
  .game-hud { height: 84px !important; }
  .hud-nivel { font-size: 1.8rem !important; }
  .hud-lives { font-size: 1.8rem !important; }
  
  .chip-fail { width: 2.5rem !important; height: 2.5rem !important; font-size: 1.2rem !important; }

  .word-display-box { padding: 3.5rem 2.5rem !important; max-height: 190px !important; }
  .word-row { gap: 1.1rem !important; }
  
  .word-tile {
    flex: 0 1 4.8rem !important;    
    max-height: 88px !important;
    font-size: 2.35rem !important;
  }

  .hint-panel { padding: 1.1rem 1.4rem !important; }
  .hint-text { font-size: 1.2rem !important; }
  .util-btn { font-size: 1.15rem !important; padding: 0.95rem 1.3rem !important; }

  .key {
    flex: 0 1 3.2rem !important;
    height: 3.2rem !important;
    max-width: 52px !important;
    font-size: 1.3rem !important;
  }
}

/* ═══════════════════════════════════════════════════════════════════════
   11. RESPONSIVE — MOBILE (≤ 768px)
═══════════════════════════════════════════════════════════════════════ */
@media (max-width: 768px) {
  .ahorcado-wrapper { height: calc(100svh - 64px); }

  .game-arena {
    flex-direction: column;
    gap: clamp(5px, 1svh, 8px);
    padding: clamp(6px, 1svh, 10px) clamp(8px, 3vw, 14px);
    flex: none;
  }

  .arena-left { flex: 0 0 auto; flex-direction: column; gap: clamp(5px, 0.8svh, 8px); }
  .hangman-frame { flex: none; height: clamp(110px, 20svh, 175px); border-radius: 10px; }
  .wrong-zone { min-height: clamp(34px, 5svh, 46px); border-radius: 8px; padding: 5px 10px; }

  .arena-right { flex: 1; min-height: 0; gap: clamp(5px, 0.8svh, 8px); }
  .word-display-box { flex: 0 0 clamp(68px, 12svh, 90px) !important; border-radius: 10px; padding: 8px; }

  .word-tile {
    flex: 0 1 2rem;
    max-height: 42px;
    font-size: clamp(0.8rem, 4vw, 1.15rem);
  }

  .hint-panel {
    flex: 1;
    padding: clamp(7px, 1svh, 12px) clamp(10px, 2vw, 16px);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hint-label { font-size: 0.65rem; margin-bottom: 3px; }
  .hint-text  { font-size: clamp(0.75rem, 2.5vw, 0.88rem); }

  .utilities-row { gap: 6px; }
  .util-btn { padding: clamp(6px, 1svh, 9px) 8px; font-size: clamp(0.65rem, 2.5vw, 0.8rem); border-radius: 6px; display: flex;
        flex-direction: column; }

  .keyboard-zone { padding: clamp(5px, 0.8svh, 9px) clamp(6px, 2vw, 12px); }
  .teclado { gap: clamp(3px, 1vw, 5px);        width: 80%; }

  .key {
    flex: 0 1 2rem;
    height: 2rem;
    font-size: clamp(0.7rem, 3.5vw, 0.88rem);
    border-radius: 5px;
    box-shadow: 0 2px 0 rgba(0,0,0,0.4);
  }

  .result-overlay { justify-content: center; align-items: center; padding: 12px; }
  .arcade-result-card { max-width: 300px !important; }
  .result-img-area { height: 120px !important; }
  .result-body { padding: 12px 16px; gap: 6px; }
  .result-title { font-size: 1.25rem !important; }
  .decoded-word { font-size: 1.15rem; }
  .metric-row { font-size: 0.78rem !important; padding: 6px 0 !important; }
}

/* ═══════════════════════════════════════════════════════════════════════
   12. MOBILE PEQUEÑO (≤ 480px)
═══════════════════════════════════════════════════════════════════════ */
@media (max-width: 480px) {
  .game-hud { height: clamp(48px, 8svh, 58px); gap: 4px; padding: 0 8px; }
  .hud-lives { gap: 3px; font-size: 0.9rem; }
  .pts-badge, .btn-menu-hud { padding: 3px 7px; font-size: 0.7rem; }
  .menu-hud-label { display: none; }
  .hangman-frame { height: clamp(95px, 17svh, 145px); }
  .key { flex: 0 1 1.65rem; height: 1.85rem; font-size: 0.75rem; }
  .teclado{ width: 80%; margin-right: 15%;}
}

/* ═══════════════════════════════════════════════════════════════════════
   13. PANTALLAS BAJAS / VENTANAS REDUCIDAS VERTICALMENTE
═══════════════════════════════════════════════════════════════════════ */
@media (max-height: 720px) {
  .word-tile { max-height: 44px !important; }
  .key { height: 1.85rem !important; font-size: 0.85rem !important; }
  .keyboard-zone { padding: 4px 10px; }
}

@media (max-height: 700px) {
  .ahorcado-wrapper {
    height: auto !important;
    min-height: calc(100svh - 74px);
    overflow-y: auto !important; 
  }
  .hangman-frame { height: 150px !important; flex: auto !important; }
  .game-layout { overflow: visible !important; }
  /* .hint-label { display: none; } */
  .hint-text { font-size: 0.85rem !important; }
  .word-display-box{     padding: 1rem 0.75rem;}
}
