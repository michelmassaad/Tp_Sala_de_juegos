  z-index: 1050;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4px 15px rgba(var(--accent-primary-rgb), 0.4);
}

.chat-toggle-btn:hover {
  transform: scale(1.1);
  box-shadow: 0 6px 20px rgba(var(--accent-primary-rgb), 0.6);
}

/* Cuando el chat se abre, el botón viaja a la izquierda acompañando el borde del panel */
.app-layout.chat-open .chat-toggle-btn {
  right: 380px; /* 350px del chat + 30px de separación */
  background: var(--bg-card); /* Se vuelve oscuro para no distraer */
  color: var(--text-main);
  border: 1px solid rgba(var(--white-rgb), 0.1);
  width: 50px; /* Se achica un poquito */
  height: 50px;
  font-size: 1.3rem;
}

/* ── BOTÓN CERRAR (X) DENTRO DEL CHAT ── */
.chat-close-btn {
  position: absolute;
  top: 16px;
  right: 16px;
  background: transparent;
  color: var(--text-muted);
  border: none;
  font-size: 1.2rem;
  cursor: pointer;
  z-index: 1060;
