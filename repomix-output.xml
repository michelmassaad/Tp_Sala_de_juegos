/* ── NAVBAR BASE ── */
.custom-navbar {
  background: linear-gradient(
    90deg,
    rgba(14, 17, 23, 0.96),
    rgba(17, 21, 30, 0.94)
  );
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 0.1px solid rgba(var(--accent-primary-rgb), 0.2);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
  position: sticky;
  top: 0;
  z-index: 1050;
}

/* Glow line inferior sutil */
.custom-navbar::after {
  content: "";
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 100%;
  height: 1px;
  background: linear-gradient(
    90deg,
    transparent,
    var(--accent-primary),
    transparent
  );
  opacity: 0.7;
  box-shadow: 0 0 10px rgba(var(--accent-primary-rgb), 0.5);
}

/* ── NAV LINKS ── */
.custom-navbar .nav-link {
  font-size: 1.1rem;
  position: relative;
  transition: all 0.3s ease;
}

.custom-navbar .nav-link::before {
  content: "";
  transition: all 0.3s ease;
  transform: translateX(-50%);
}

.custom-navbar .nav-link:hover {
  color: var(--accent-primary) !important;
  text-shadow: 0 0 8px rgba(var(--accent-primary-rgb), 0.6);
}


.custom-navbar .nav-link.active {
  color: var(--accent-primary) !important;
  text-shadow: 0 0 10px rgba(var(--accent-primary-rgb), 0.4);
}

.custom-navbar .nav-link.active::before { width: 80%; }

.custom-navbar .nav-link:focus,
.custom-navbar .nav-link:focus-visible {
  outline: none;
  box-shadow: none;
  background: transparent;
}

/* ── TOGGLER (Menú Hamburguesa) ── */
.navbar-toggler {
  width: 40px;
  height: 40px;
  padding: 0;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(var(--white-rgb), 0.1);
  border-radius: 8px;
  background: rgba(var(--white-rgb), 0.02);
  transition: all 0.2s ease;
  
}

.navbar-toggler:hover {
  background: rgba(var(--white-rgb), 0.08);
    outline: none;
  box-shadow: none;
  background: transparent;
}

.navbar-toggler:focus {
  outline: none;
  box-shadow: 0 0 0 2px rgba(var(--accent-primary-rgb), 0.3);
    outline: none;
  box-shadow: none;
  background: transparent;
}

/* ── AVATAR (Para Mobile y Desktop) ── */
.user-avatar {
  width: 28px; /* Aumentado levemente para que la letra respire */
  height: 28px;
  border-radius: 5px; /* Tu estilo cuadradito redondeado */
  background-color: var(--accent-primary);
  color: var(--bg-base);
  font-size: 1.1rem; /* Letra un poquito más grande */
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ── CÁPSULA (Launcher Pill Desktop) ── */
.launcher-pill {
  background: rgba(var(--white-rgb), 0.03);
  border: 1px solid rgba(var(--accent-primary-rgb), 0.20); /* 1px se ve mejor que 0.5px en muchos monitores */
  border-radius: 14px; /* 14px abraza perfecto al avatar de 10px */
  padding: 6px 8px; /* Un poquito más de aire arriba y abajo */
  transition: all 0.3s ease;
}

.launcher-pill:hover {
  background: rgba(var(--accent-primary-rgb), 0.05);
  border-color: rgba(var(--accent-primary-rgb), 0.5);
  box-shadow: 0 0 18px rgba(var(--accent-primary-rgb), 0.15);
  transform: translateY(-1px);
}

/* ── INFO DEL USUARIO ── */
.user-info {
  margin-left: 14px; /* Más aire a los costados */
