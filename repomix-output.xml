<div class="container py-4 text-center">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">

      <div class="d-flex align-items-center justify-content-between mb-4">
        <button class="btn btn-custom-outline btn-sm px-3" (click)="volver()">
          <i class="bi bi-arrow-left me-1"></i> Volver
        </button>
        <h2 class="fun-title mb-0">Preguntados</h2>
        <div class="pts-badge timer-badge tech-font">
          <i class="bi bi-stopwatch me-1"></i>{{ cronometro.tiempoFormateado() }}
        </div>
      </div>

      @if (loading()) {
        <div class="card custom-card p-5 text-center">
          <div class="spinner-border text-primary mx-auto mb-3" role="status"></div>
          <p class="text-muted fw-bold m-0">Invocando preguntas desde la API...</p>
        </div>
      }

      @if (juegoIniciado() && !juegoTerminado() && preguntaActual()) {
        <div class="card custom-card p-4 text-start animate-fade-in">
          <div class="d-flex justify-content-between text-secondary small fw-bold mb-3 border-bottom border-secondary border-opacity-25 pb-2">
            <span>{{ preguntaActual()?.category }}</span>
            <span class="text-primary">Pregunta {{ indiceActual() + 1 }} de 10</span>
          </div>

        <h4 class="text-white mb-4 lh-base fw-bold" [innerHTML]="preguntaActual()?.question"></h4>

          <div class="d-flex flex-column gap-3">
            @for (opcion of preguntaActual()?.all_answers; track opcion) {
              <button class="btn text-start trivia-btn py-3 px-4 fw-bold"
                [disabled]="respondido()"
                [class.btn-correct]="respondido() && opcion === preguntaActual()?.correct_answer"
                [class.btn-incorrect]="respondido() && respuestaSeleccionada() === opcion && opcion !== preguntaActual()?.correct_answer"
                (click)="verificarRespuesta(opcion)" [innerHTML]="opcion">>
              </button>
            }
          </div>

          <div class="text-center mt-3 text-muted small fw-bold">
            Aciertos actuales: <span class="text-success">{{ acertadas() }}</span>
          </div>
        </div>
      }

      @if (juegoTerminado()) {
        <div class="card custom-card p-5 text-center animate-scale-up">
          @if (victoria()) {
            <p class="display-3 mb-2">🧠🏆</p>
            <h2 class="text-success fw-bold text-uppercase tracking-wider">Stage Clear</h2>
          } @else {
            <p class="display-3 mb-2">🃏❌</p>
            <h2 class="text-warning fw-bold text-uppercase tracking-wider">Game Over</h2>
          }

          <p class="text-secondary mt-3 mb-1">Puntaje acumulado: <strong class="text-primary">{{ puntaje() }} PTS</strong></p>
          <p class="text-secondary mb-4">Respuestas correctas: <strong class="text-success">{{ acertadas() }} / 10</strong></p>

          @if (guardando()) {
            <p class="text-muted small mb-3">
              <span class="spinner-border spinner-border-sm me-2"></span>Sincronizando con base de datos...
            </p>
          }

          <button class="btn btn-accent fw-bold px-5 py-2.5 rounded-pill" (click)="reiniciar()">
            <i class="bi bi-arrow-repeat me-2"></i>Jugar de nuevo
          </button>
        </div>
      }

    </div>
  </div>
</div>
</file>

