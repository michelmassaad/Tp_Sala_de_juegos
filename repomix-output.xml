<file path="src/app/components/registro/registro.html">
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5">

      <div class="card custom-card p-4 p-sm-5">
        <div class="card-body p-0">

          <h2 class="fun-title text-center mb-1 fs-2">Crea tu cuenta</h2>
          <p class="text-center text-secondary small mb-4">Regístrate en la Sala de Juegos</p>

          <form [formGroup]="registroForm" (ngSubmit)="onSubmit()">

            <div class="row">
              
              <div class="col-12 col-sm-6 mb-3">
                <label for="nombre" class="form-label text-secondary small mb-1">Nombre</label>
                <input id="nombre" type="text" formControlName="nombre" class="form-control custom-input"
                       [class.is-invalid]="registroForm.get('nombre')?.invalid && registroForm.get('nombre')?.touched">
                
                @if(registroForm.get('nombre')?.invalid && registroForm.get('nombre')?.touched){
                  <div class="text-danger small mt-1 ms-1 fw-bold lh-sm">
                    @if(registroForm.get('nombre')?.errors?.['required']){ <span><i class="bi bi-asterisk me-1"></i>Requerido.</span><br> }
                    @if(registroForm.get('nombre')?.errors?.['minlength']){ <span><i class="bi bi-dash-circle me-1"></i>Mínimo 2 letras.</span><br> }
                    @if(registroForm.get('nombre')?.errors?.['soloLetras']){ <span><i class="bi bi-alphabet me-1"></i>Solo letras permitidas.</span> }
                  </div>
                }
              </div>

              <div class="col-12 col-sm-6 mb-3">
                <label for="apellido" class="form-label text-secondary small mb-1">Apellido</label>
                <input id="apellido" type="text" formControlName="apellido" class="form-control custom-input"
                       [class.is-invalid]="registroForm.get('apellido')?.invalid && registroForm.get('apellido')?.touched">
                
                @if(registroForm.get('apellido')?.invalid && registroForm.get('apellido')?.touched){
                  <div class="text-danger small mt-1 ms-1 fw-bold lh-sm">
                    @if(registroForm.get('apellido')?.errors?.['required']){ <span><i class="bi bi-asterisk me-1"></i>Requerido.</span><br> }
                    @if(registroForm.get('apellido')?.errors?.['minlength']){ <span><i class="bi bi-dash-circle me-1"></i>Mínimo 2 letras.</span><br> }
                    @if(registroForm.get('apellido')?.errors?.['soloLetras']){ <span><i class="bi bi-alphabet me-1"></i>Solo letras permitidas.</span> }
                  </div>
                }
              </div>
            </div>

            <div class="mb-3">
              <label for="edad" class="form-label text-secondary small mb-1">Edad</label>
              <input id="edad" type="number" formControlName="edad" class="form-control custom-input"
                     [class.is-invalid]="registroForm.get('edad')?.invalid && registroForm.get('edad')?.touched">
              
              @if(registroForm.get('edad')?.invalid && registroForm.get('edad')?.touched){
                <div class="text-danger small mt-1 ms-1 fw-bold">
                  @if(registroForm.get('edad')?.errors?.['required']){ <span><i class="bi bi-asterisk me-1"></i>La edad es obligatoria.</span> }
                  @if(registroForm.get('edad')?.errors?.['min'] || registroForm.get('edad')?.errors?.['max']){ <span><i class="bi bi-exclamation-circle me-1"></i>Edad inválida (1-120).</span> }
                </div>
              }
            </div>

            <div class="mb-3">
              <label for="email" class="form-label text-secondary small mb-1">Email</label>
              <input id="email" type="email" formControlName="email" class="form-control custom-input"
                     [class.is-invalid]="registroForm.get('email')?.invalid && registroForm.get('email')?.touched">
              
              @if(registroForm.get('email')?.invalid && registroForm.get('email')?.touched){
                <div class="text-danger small mt-1 ms-1 fw-bold lh-sm">
                  @if(registroForm.get('email')?.errors?.['required']){ <span><i class="bi bi-asterisk me-1"></i>El email es obligatorio.</span><br> }
                  @if(registroForm.get('email')?.errors?.['email']){ <span><i class="bi bi-x-circle me-1"></i>El formato es inválido.</span> }
                </div>
              }
            </div>

            <div class="mb-4">
              <label for="password" class="form-label text-secondary small mb-1">Contraseña</label>

              <div class="password-wrapper">
                <input id="password" [type]="mostrarPassword() ? 'text' : 'password'" formControlName="password"
                  autocomplete="off" class="form-control custom-input pe-5"
                  [class.is-invalid]="registroForm.get('password')?.invalid && registroForm.get('password')?.touched">

                <button type="button" class="toggle-password-btn" (click)="habilitarPassword()" tabindex="-1">
                  <i class="bi" [ngClass]="mostrarPassword() ? 'bi-eye-slash-fill' : 'bi-eye-fill'"></i>
                </button>
              </div>

              @if(registroForm.get('password')?.invalid && registroForm.get('password')?.touched){
                <div class="text-danger small mt-1 ms-1 fw-bold lh-sm">
                  @if(registroForm.get('password')?.errors?.['required']){ <span><i class="bi bi-asterisk me-1"></i>La contraseña es obligatoria.</span><br> }
                  @if(registroForm.get('password')?.errors?.['minlength']){ <span><i class="bi bi-shield-lock me-1"></i>El mínimo es de 6 caracteres.</span> }
                </div>
              }
            </div>

            @if (errorMensaje()) {
            <div class="alert custom-alert py-2 mb-4 small">
              <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ errorMensaje() }}
            </div>
            }

            @if (mensajeExito()) {
            <div class="alert custom-success-alert py-2 mb-4 small">
              <i class="bi bi-check-circle-fill me-2 fs-5"></i>{{ mensajeExito() }}
            </div>
            }

            <button type="submit" class="btn btn-accent w-100 fw-bold py-2" [disabled]="registroForm.invalid || loading()">
              @if (loading()) {
              <span class="spinner-border spinner-border-sm me-2"></span> Registrando...
              } @else {
              <i class="bi bi-person-plus-fill me-2"></i>Registrarse
              }
            </button>
          </form>

          <hr class="text-muted my-4">

          <p class="text-center text-secondary small mb-0">
            ¿Ya tenés cuenta?
            <a routerLink="/login" class="text-accent fw-bold text-decoration-none">Ingresar</a>
          </p>

        </div>
      </div>

    </div>
  </div>
</div>
</file>

