/* ======================================================= */
/* COMPONENTES DE LOGIN (Alimentados por styles.css global)*/
/* ======================================================= */

/* --- Inputs Oscuros --- */
.custom-input {
  background-color: var(--bg-base);
  border: 1px solid rgba(var(--white-rgb), 0.1);
  color: var(--text-main);
  transition: all 0.3s ease;
}

.custom-input:focus {
  background-color: var(--bg-base);
  color: var(--text-main);
  border-color: var(--accent-primary);
  /* Resplandor cyan al hacer clic en el input */
  box-shadow: 0 0 0 0.25rem rgba(var(--accent-primary-rgb), 0.25);
}

/* --- Botón Principal (Accent Primary) --- */
.btn-accent {
  background-color: var(--accent-primary);
  /* Texto oscuro (--bg-base) para que contraste perfecto con el cyan claro */
  color: var(--bg-base); 
  border: none;
  transition: all 0.3s ease;
}

.btn-accent:hover:not(:disabled) {
  background-color: var(--accent-primary);
  color: var(--bg-base);
  /* Oscurece apenitas el botón y le da un brillo cyan */
  filter: brightness(0.9);
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(var(--accent-primary-rgb), 0.4);
}

/* --- Botones de Prueba (Login Rápido) --- */
.btn-custom-outline {
  background-color: transparent;
  border: 1px solid rgba(var(--white-rgb), 0.15);
  color: var(--text-main);
  transition: all 0.3s ease;
}

.btn-custom-outline:hover:not(:disabled) {
  border-color: var(--accent-primary);
  color: var(--accent-primary);
  background-color: rgba(var(--accent-primary-rgb), 0.05);
}

/* --- Enlace de Registro --- */
.text-accent {
  color: var(--accent-primary);
  transition: all 0.3s ease;
}

.text-accent:hover {
  color: var(--accent-primary);
  filter: brightness(1.2);
  text-shadow: 0 0 8px rgba(var(--accent-primary-rgb), 0.4);
}

/* --- Alerta de Error --- */
/* Estilo sutil para que el cartel rojo no rompa la estética dark */
.custom-alert {
  background-color: rgba(220, 53, 69, 0.1);
  border: 1px solid rgba(220, 53, 69, 0.4);
  color: #ff6b6b;
}


/* ======================================================= */
/* INPUT DE CONTRASEÑA CON OJITO                           */
/* ======================================================= */

/* La caja contenedora (clave para que el botón no se escape) */
.password-wrapper {
  position: relative;
  display: block;
}

/* El botón transparente y flotante */
.toggle-password-btn {
  position: absolute;
  top: 50%;
  right: 12px;
  transform: translateY(-50%); /* Centrado matemático vertical */
  background: transparent;
  border: none;
  color: var(--text-muted);
  cursor: pointer;
  z-index: 10;
  padding: 0;
  display: flex;
  align-items: center;
  transition: color 0.3s ease;
}

/* Brillo con tu color cuando se pasa el mouse */
.toggle-password-btn:hover {
  color: var(--accent-primary);
}

/* Sacamos el borde feo que le ponen los navegadores al hacer clic */
.toggle-password-btn:focus {
  outline: none;
}

.custom-success-alert {
  background-color: rgba(52, 211, 153, 0.1); 
  border: 1px solid rgba(52, 211, 153, 0.4); 
  color: #34d399; /* Verde esmeralda que usás en tu logo */
  animation: slideDownFade 0.3s ease forwards;
}

/* Estilo dinámico cuando el input tiene un error de Angular */
.custom-input.is-invalid {
  border-color: #ff6b6b !important;
  box-shadow: 0 0 8px rgba(220, 53, 69, 0.4) !important;
  color: #ff6b6b;
  
  /* 👇 LA SOLUCIÓN AL PROBLEMA DEL OJITO 👇 */
  background-image: none !important; 
}

/* Para que el input no pierda el estilo rojo al hacerle click de nuevo */
.custom-input.is-invalid:focus {
  border-color: #dc3545 !important;
  box-shadow: 0 0 12px rgba(220, 53, 69, 0.6) !important;
}
