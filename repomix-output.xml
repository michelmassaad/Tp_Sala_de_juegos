  font-weight: 700;
  color: var(--text-main);
  line-height: 1;
}

/* ── SEPARADOR VERTICAL ── */
.pill-separator {
  width: 1px;
  height: 26px; /* Un poco más alto para acompañar el nuevo tamaño */
  background: rgba(var(--white-rgb), 0.15);
  margin-right: 10px; /* Más espacio antes del botón power */
}

/* ── BOTÓN POWER (Desktop) ── */
.btn-power-launcher {
  background: transparent;
  border: none;
  color: var(--text-muted);
  width: 25px; /* Mismo tamaño que el avatar para mantener simetría */
  height: 25px;
  border-radius: 10px; /* Mismo estilo que el avatar */
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
  cursor: pointer;
  transition: all 0.2s ease;
  padding: 0;
}

.btn-power-launcher:hover {
  color: #ff6b6b;
  background: rgba(220, 53, 69, 0.12);
  transform: scale(1.1);
  box-shadow: 0 0 10px rgba(220, 53, 69, 0.2);
}

/* ── BOTÓN SALIR (Mobile) ── */
.btn-salir {
  width: 100%;
  padding: 10px 20px;
  border-radius: 12px;
  background: rgba(220, 53, 69, 0.05);
  border: 1px solid rgba(220, 53, 69, 0.35);
  color: #ff6b6b;
  font-weight: 700;
  font-size: 0.95rem;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-salir:hover {
  background: rgba(220, 53, 69, 0.15);
  border-color: #ff6b6b;
  box-shadow: 0 0 12px rgba(220, 53, 69, 0.2);
  transform: translateY(-2px);
}

/* ══════════════════════════════════════ */
/* 📱 🌟 FIX RESPONSIVO: MENOS DE 450PX   */
/* ══════════════════════════════════════ */
@media (max-width: 450px) {
  /* Ocultamos el texto de la marca para ganar el espacio que rompía el layout */
  .navbar-text-brand {
    display: none !important;
  }

  /* Reducimos los paddings del contenedor para estirar la barra al borde */
  .custom-navbar .container-fluid {
    padding-left: 12px !important;
    padding-right: 12px !important;
  }

  /* Evitamos que el logo tenga un margen extra que empuje al avatar móvil */
  .custom-navbar .navbar-brand {
    margin-right: 0 !important;
  }
}
