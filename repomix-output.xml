}
/* ═══════════════════════════════════════════════
   MÓDULO RESPONSIVE UNIFICADO PARA CELULARES (TRUCO CSS)
   ═══════════════════════════════════════════════ */
@media (max-width: 768px) {
  /* Achicamos la burbuja del chat flotante cuando el juego está visible */
  .chat-toggle-btn {
    width: 42px !important;
    height: 42px !important;
    bottom: 12px !important;
    right: 12px !important;
    font-size: 1.1rem !important;
  }

.chat-sidebar {
  position: fixed;
  top: 50%; /* Justo debajo de tu navbar */
