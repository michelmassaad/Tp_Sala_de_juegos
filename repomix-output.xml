            <i class="bi"
              [class.bi-heart-fill]="$index < intentosRestantes()"
              [class.bi-heart]="$index >= intentosRestantes()"
              [class.life-active]="$index < intentosRestantes()"
              [class.life-lost]="$index >= intentosRestantes()">
            </i>
          }
